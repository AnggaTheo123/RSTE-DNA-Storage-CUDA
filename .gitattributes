# Default behavior — normalize line endings
* text=auto

# Source files
*.cpp text eol=lf
*.cu  text eol=lf
*.cuh text eol=lf
*.hpp text eol=lf
*.h   text eol=lf
*.py  text eol=lf
*.md  text eol=lf
*.txt text eol=lf

# Windows scripts keep CRLF
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Treat as binary so git does not modify them
*.pdf binary
*.jpg binary
*.png binary
*.docx binary
*.xlsx binary
*.nsys-rep binary
*.sqlite binary
